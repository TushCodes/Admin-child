# Local development defaults. Copy to .env.local or run scripts/bootstrap_local.sh.
FLASK_ENV=development
SECRET_KEY=dev-local-secret-key-change-me
DATABASE_URL=postgresql://admin_child:admin_child@127.0.0.1:5432/admin_child

# Admin auth defaults to Supabase when SUPABASE_URL + a Supabase auth key are set.
# For production-style local verification, create a Supabase Auth user and set:
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_AUTH_KEY=your-supabase-anon-key
# ADMIN_AUTH_PROVIDER=supabase
# Use SUPABASE_AUTH_DISABLE_LOCAL_FALLBACK=true to prevent local fallback in development.
ADMIN_AUTH_PROVIDER=local
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin-pass

AUTO_CREATE_TABLES=true
PORT=5000
